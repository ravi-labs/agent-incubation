# ──────────────────────────────────────────────────────────────────────────────
# arc — environment template for local + sandbox dev
# ──────────────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and fill in real values for the section(s) you
# need. The CLI, HarnessBuilder, and RuntimeBuilder load `.env` at startup
# via `arc.core.load_env_file()`. Shell-set vars always win — `.env` is
# the fallback layer below the shell.
#
# For production deploys (AWS Lambda / ECS / Bedrock Agents): DO NOT ship
# this file. Production gets env from the platform's task / function config
# (with secrets pulled from AWS Secrets Manager). The loader is a no-op
# when no `.env` exists, so production stays clean by default.
#
# Documentation: docs/guides/configuration.md (precedence + AWS deploy story)
# ──────────────────────────────────────────────────────────────────────────────


# ── AWS credentials (for Bedrock LLM, DynamoDB, S3, etc.) ─────────────────────
# Pick ONE of: explicit access keys, AWS profile, or IAM role.
# Skip these entirely if you're using `aws sso login` or an instance profile.

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_PROFILE=arc-sandbox

# Required for Bedrock + most boto3 clients. `AWS_DEFAULT_REGION` works too.
AWS_REGION=us-east-1


# ── arc LLM config — platform default for every agent ────────────────────────
# Read by `arc.core.LLMConfig.from_env()`. Per-agent override goes in the
# agent's manifest.yaml under `llm:`. See docs/concepts/llm-clients.md.

ARC_LLM_PROVIDER=bedrock              # "bedrock" | "litellm" | empty (no LLM)
ARC_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# ARC_LLM_REGION=us-east-1            # falls back to AWS_REGION if unset
# ARC_LLM_FALLBACK_MODELS=anthropic.claude-3-haiku-20240307-v1:0     # litellm only
# ARC_LLM_API_BASE=https://litellm.internal.example.com/v1           # litellm only
# ARC_LLM_MAX_RETRIES=3


# ── Bedrock-specific (read by arc-runtime's BedrockConfig) ────────────────────
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0


# ── Outlook integration (Microsoft Graph) ─────────────────────────────────────
# Required only when an agent declares `email.read` and the runtime is
# wiring a real OutlookConnector. Skip if your pilot uses a mock mailbox.

# OUTLOOK_TENANT_ID=...
# OUTLOOK_CLIENT_ID=...
# OUTLOOK_CLIENT_SECRET=...
# OUTLOOK_INBOX_USER=triage-pilot@your-org.com    # the mailbox to monitor


# ── Pega Case Management ──────────────────────────────────────────────────────
# Required when TICKET_TARGET=pega. See docs/guides/pega-integration.md
# for sandbox setup + payload-shape work.

# PEGA_BASE_URL=https://your-tenant.pegacloud.io
# PEGA_CLIENT_ID=...
# PEGA_CLIENT_SECRET=...
# PEGA_CASE_TYPE=ITSM-Work-AutoClaim   # default; per-case schemas in pega_schemas/

# Pega Knowledge Base (optional)
# PEGA_KB_BASE_URL=https://kb.pegacloud.io
# PEGA_KB_API_KEY=...


# ── ServiceNow Case Management ────────────────────────────────────────────────
# Required when TICKET_TARGET=servicenow. ServiceNow's REST API is dramatically
# simpler than Pega's — good fallback if Pega integration stalls.

# SNOW_INSTANCE_URL=https://your-instance.service-now.com
# SNOW_CLIENT_ID=...
# SNOW_CLIENT_SECRET=...
# SNOW_TABLE=incident                  # default


# ── Routing — pick which ticketing system the agent talks to ─────────────────

TICKET_TARGET=pega                     # "pega" | "servicenow"


# ── Audit + observability ─────────────────────────────────────────────────────
# Production should override these to a managed sink (CloudWatch, S3).
# JSONL is the default — appropriate for dev + sandbox; not for prod scale.

ARC_AUDIT_SINK=jsonl                   # "jsonl" | "cloudwatch" | "s3"
ARC_AUDIT_PATH=arc_audit.jsonl
# ARC_LOG_LEVEL=INFO


# ── Approver mode (Tollgate) ──────────────────────────────────────────────────
# How DEFERRED decisions get to a human reviewer. CLI prompts the dev in the
# terminal; sqs uses an AsyncQueueApprover backed by SQS + DynamoDB.

ARC_APPROVER_MODE=cli                  # "cli" | "sqs" | "webhook"
# ARC_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/.../arc-approvals
# ARC_APPROVALS_TABLE=arc-pending-approvals
# ARC_APPROVAL_TIMEOUT=86400           # seconds; 24h default


# ── Agent runtime / locator ──────────────────────────────────────────────────
# Optional. Defaults work for the local + sandbox path.

# ARC_ENV=sandbox                      # "sandbox" | "production"
# ARC_MANIFEST_PATH=arc/agents/email-triage/manifest.yaml
# ARC_POLICY_DIR=policies/


# ── AgentCore (AWS-managed agent runtime — optional) ─────────────────────────
# Set only when deploying through Bedrock AgentCore.

# AGENTCORE_AGENT_ID=...
# AGENTCORE_MEMORY_ID=...


# ── Auto-demotion watcher ─────────────────────────────────────────────────────
# Read by `arc agent watch` and the DemotionWatcher. The kill switch
# disables the watcher entirely without changing any other config.

# ARC_AUTO_DEMOTE_DISABLED=1           # set to bypass the watcher
