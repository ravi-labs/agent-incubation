# ─────────────────────────────────────────────────────────────────────────────
# Root .gitignore — agent-incubation mono-repo
#
# This file covers repo-wide noise. Each subfolder has its own .gitignore
# for technology-specific patterns.
# ─────────────────────────────────────────────────────────────────────────────

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Linux ────────────────────────────────────────────────────────────────────
*~

# ── IDEs / editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Secrets — never commit credentials ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
