# ─────────────────────────────────────────────────────────────────────────────
# Root .gitignore — agent-incubation mono-repo
#
# This file covers repo-wide noise. Each subfolder has its own .gitignore
# for technology-specific patterns.
# ─────────────────────────────────────────────────────────────────────────────

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Linux ────────────────────────────────────────────────────────────────────
*~

# ── IDEs / editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Secrets — never commit credentials ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Python build / cache ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ── Runtime artifacts (audit logs, outcome traces, generated reports) ───────
*_audit.jsonl
*_outcomes.jsonl
audit-report-sample.html
.claude/

# ── Personal learning + scratch notes (per-developer, never committed) ──────
# `learn/` is a freeform place for interactive HTML primers, sketch
# diagrams, working notes — anything you want local to your checkout.
learn/
