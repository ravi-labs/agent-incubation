# ─────────────────────────────────────────────────────────────────────────────
# agent-team-template/.gitignore — starter template for agent teams
#
# When teams copy this template into their own repo, they inherit this file.
# It covers everything a typical agent team repo will generate locally.
# ─────────────────────────────────────────────────────────────────────────────

# ── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so

# ── Build / packaging ────────────────────────────────────────────────────────
dist/
build/
*.egg
*.egg-info/
.eggs/
*.whl

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ── Linters ───────────────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── Runtime-generated files ───────────────────────────────────────────────────
# Audit logs and outcome events written by agents during local runs
*.jsonl
*.sqlite
*.sqlite3

# ── Local development overrides ───────────────────────────────────────────────
# Teams may create local policy overrides for testing — never commit these
agents/*/policy.local.yaml
agents/*/manifest.local.yaml
